{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "noEmit": true,
    "paths": {
      "@orz-people-platform/utils": [
        "packages/utils/src"
      ]
    }
  },
  "include": [
    "app/backend/src/**/*.ts",
    "app/backend/test/**/*.ts",
    "app/frontend/**/*.ts",
    "app/frontend/**/*.mts",
    "app/frontend/**/*.vue",
    "packages/**/*.ts"
  ]
}
