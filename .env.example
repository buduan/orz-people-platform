# For Development
PORT=3000
NUXT_PORT=3001

# Application ports exposed by Docker Compose
BACKEND_PORT=
FRONTEND_PORT=3001

# PostgreSQL
POSTGRES_DB=orz_people
POSTGRES_USER=orz
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-in-production
REDIS_URL=redis://:change-me-in-production@localhost:6379/0

# Optional local delivery test services (`pnpm start:delivery`)
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
DELIVERY_SINK_PORT=8085

# Nuxt public runtime configuration
NUXT_PUBLIC_API_BASE=http://localhost:3000
