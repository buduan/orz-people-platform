{
  "name": "@orz-people-platform/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host 0.0.0.0",
    "dev:test": "nuxt dev --host 127.0.0.1 --port 3301",
    "preview": "nuxt preview --host 0.0.0.0",
    "test:component": "vitest run --config vitest.config.mts",
    "test:e2e": "playwright test",
    "typecheck": "pnpm --filter @orz-people-platform/types build && pnpm --filter @orz-people-platform/utils build && nuxt typecheck"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.23",
    "@nuxt/ui": "^3.3.7",
    "@orz-people-platform/types": "workspace:*",
    "@orz-people-platform/utils": "workspace:*",
    "better-auth": "^1.6.23",
    "dotenv": "^16.6.1",
    "nuxt": "catalog:",
    "openapi-fetch": "0.17.0",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@iconify-json/solar": "^1.2.5",
    "@nuxt/test-utils": "4.0.3",
    "@playwright/test": "1.61.1",
    "@vue/test-utils": "2.4.11",
    "happy-dom": "20.10.6",
    "openapi-typescript": "7.13.0",
    "vitest": "4.1.10"
  }
}
