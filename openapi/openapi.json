                          "example": "orz-people-platform-backend"
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "ok",
                            "ready"
                          ]
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "required": [
                        "requestId",
