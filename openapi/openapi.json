                      ],
                      "properties": {
                        "requestId": {
                          "type": "string",
                          "maxLength": 128,
                          "pattern": "^[A-Za-z0-9._:-]+$"
                        },
                        "timestamp": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    }
